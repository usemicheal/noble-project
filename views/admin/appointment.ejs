<%- include('../partials/header', { title: 'Appointment - Admin Dashboard' }) %> <%-
include('../partials/nav', { page: 'appointment' }) %> <%- include('../partials/toast') %>

<div class="bg-white rounded-lg shadow overflow-hidden">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead class="bg-gray-100">
        <tr>
          <th class="px-4 py-3 text-left text-sm font-medium">Sender</th>
          <th class="px-4 py-3 text-left text-sm font-medium">Subject</th>
          <th class="px-4 py-3 text-left text-sm font-medium">Amount</th>
          <th class="px-4 py-3 text-left text-sm font-medium">Approval</th>
          <th class="px-4 py-3 text-left text-sm font-medium">Action</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% appointment.forEach(app => { %>
        <tr>
          <td class="px-4 py-3 text-sm">
            <div class="font-bold"><%= app.sender_name %></div>
            <div class="text-xs text-gray-500"><%= app.sender_email %></div>
          </td>
          <td class="px-4 py-3 text-sm"><%= app.sender_subject %></td>
          <td class="px-4 py-3 text-sm font-bold text-blue-600">
            $<%= app.booking_amount.toLocaleString() %>
          </td>
          <td class="px-4 py-3 text-sm">
            <% if (app.isApproved) { %>
            <span class="px-2 py-1 bg-green-100 text-green-700 rounded-full text-xs">Approved</span>
            <% } else { %>
            <span class="px-2 py-1 bg-yellow-100 text-yellow-700 rounded-full text-xs"
              >Pending</span
            >
            <% } %>
          </td>
          <td class="px-4 py-3 text-sm">
            <button
              onclick="showAppModal('<%= app._id %>')"
              class="px-3 py-1 bg-gray-100 hover:bg-gray-200 rounded text-black"
            >
              View Details
            </button>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<div
  id="appModal"
  class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50"
>
  <div class="bg-white rounded-lg max-w-lg w-full shadow-xl">
    <div class="p-6">
      <div class="flex justify-between items-center mb-4 border-b pb-2">
        <h2 class="text-xl font-bold">Appointment Details</h2>
        <button onclick="closeModal()" class="text-2xl text-gray-400 hover:text-black">
          &times;
        </button>
      </div>

      <div id="modalContent" class="space-y-4"></div>

      <div class="flex gap-3 mt-8 border-t pt-4">
        <button
          id="approveBtn"
          class="flex-1 px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 transition"
        >
          Approve Appointment
        </button>
        <button
          id="deleteBtn"
          class="px-4 py-2 bg-red-50 text-red-600 rounded hover:bg-red-100 transition"
        >
          Delete
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  // Ensure your backend passes "appointments" variable
  const appointments = <%- JSON.stringify(appointment) %>;

  function showAppModal(appId) {
      const app = appointments.find(a => a._id === appId);
      if (!app) return;

      const content = `
          <div class="grid grid-cols-2 gap-2 text-sm">
              <div class="text-gray-500">Sender:</div><div class="font-medium">${app.sender_name}</div>
              <div class="text-gray-500">Email:</div><div class="font-medium">${app.sender_email}</div>
              <div class="text-gray-500">Amount:</div><div class="font-bold text-green-600">$${app.booking_amount.toLocaleString()}</div>
              <div class="text-gray-500">Subject:</div><div class="font-medium">${app.sender_subject}</div>
          </div>
          <div class="mt-4">
              <div class="text-gray-500 text-sm mb-1">Message/Description:</div>
              <div class="p-3 bg-gray-50 rounded text-sm border italic">"${app.sender_mssg}"</div>
          </div>
      `;

      document.getElementById('modalContent').innerHTML = content;
      document.getElementById('appModal').classList.remove('hidden');

      // Toggle visibility of approve button if already approved
      const approveBtn = document.getElementById('approveBtn');
      if(app.isApproved) {
          approveBtn.classList.add('hidden');
      } else {
          approveBtn.classList.remove('hidden');
          approveBtn.onclick = () => approveAppointment(appId);
      }

      document.getElementById('deleteBtn').onclick = () => deleteAppointment(appId);
  }

  function closeModal() {
      document.getElementById('appModal').classList.add('hidden');
  }

  async function approveAppointment(id) {
      if (!confirm('Approve this MedBed appointment?')) return;
      try {
          const res = await fetch(`/admin/appointment/${id}/approve`, { method: 'POST' });
          const data = await res.json();
          alert(data.mssg || 'Status updated');
          location.reload();
      } catch (err) {
          alert('Error updating appointment');
      }
  }

  async function deleteAppointment(id) {
      if (!confirm('Permanently delete this record?')) return;
      try {
          const res = await fetch(`/admin/appointment/${id}`, { method: 'DELETE' });
          const data = await res.json();
          alert(data.mssg || 'Record deleted');
          location.reload();
      } catch (err) {
          alert('Error deleting appointment');
      }
  }
</script>
