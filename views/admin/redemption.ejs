<!-- ============================================ -->
<!-- views/redemption.ejs -->
<!-- ============================================ -->

<%- include('../partials/header', { title: 'Redemption Form - Admin Dashboard' }) %>
<%- include('../partials/nav', { page: 'redemption' }) %>
    <%- include('../partials/toast') %>

    <div class="bg-white rounded-lg shadow overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-gray-100">
                    <tr>
                        <th class="px-4 py-3 text-left text-sm font-medium">User</th>
                        <th class="px-4 py-3 text-left text-sm font-medium">Email</th>
                        <th class="px-4 py-3 text-left text-sm font-medium">Submitted At</th>
                        <!-- <th class="px-4 py-3 text-left text-sm font-medium">Status</th> -->
                        <th class="px-4 py-3 text-left text-sm font-medium">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-200">
                    <% redemptions.forEach(redemption => { %>
                    <tr>
                        <td class="px-4 py-3 text-sm"><%= redemption.user && redemption.user.fullname ? redemption.user.fullname : 'Deleted User' %></td>
                        <td class="px-4 py-3 text-sm"><%= redemption.user && redemption.user.email ? redemption.user.email : 'Deleted User' %></td>
                        <td class="px-4 py-3 text-sm">
                        <%= new Date(redemption.createdAt).toLocaleString() %>
                        </td>
                        <!-- <td class="px-4 py-3 text-sm">
                            <% if (redemption.status === 'pending') { %>
                                <span class="text-yellow-600"><%= redemption.status %></span>
                            <% } else if (redemption.status === 'under_review') { %>
                                <span class="text-green-600"><%= redemption.status %></span>
                            <% } else { %>
                                <span class="text-red-600"><%= redemption.status %></span>
                            <% } %>
                        </td> -->
                        <td class="px-4 py-3 text-sm">
                            <button onclick="showRedemptionModal('<%= redemption._id %>')" class="text-black hover:underline">View</button>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- redemption MODAL -->
<div id="redemptionModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
    <div class="bg-white rounded-lg max-w-2xl w-full max-h-screen overflow-y-auto">
        <div class="p-6">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-xl font-bold">Redemption Form Details</h2>
                <button onclick="closeModal()" class="text-2xl">&times;</button>
            </div>
            <div id="modalContent" class="space-y-3 text-sm"></div>
            <div class="flex gap-3 mt-6">
                <!-- <button id="approveBtn" class="px-4 py-2 bg-gray-800 text-white rounded hover:bg-gray-700">Approve</button> -->
                <button id="deleteBtn" class="px-4 py-2 bg-red-500 text-white rounded hover:bg-gray-900">Delete</button>
            </div>
        </div>
    </div>
</div>

<script>
    const redemptions = <%- JSON.stringify(redemptions) %>;

    function showRedemptionModal(redemptionId) {
        const redemption = redemptions.find(k => k._id === redemptionId);
        if (!redemption) return;

        const content = `
            <div><strong>User:</strong> ${redemption.user && redemption.user.fullname ? redemption.user.fullname : "Deleted User"}</div>
            <div><strong>Email:</strong> ${redemption.user && redemption.user.email ? redemption.user.email : "Deleted User"}</div>
            <div><strong>Redemption Form File:</strong></div>
           <a 
            href="${redemption.redemption_file}" 
            target="_blank" 
            class="btn btn-sm btn-primary rounded shadow-sm"
            download
            >
            <i class="bi bi-file-earmark-arrow-down me-1"></i>
            Download Uploaded Redemption Form (PDF)
            </a>

        `;
        
        document.getElementById('modalContent').innerHTML = content;
        document.getElementById('redemptionModal').classList.remove('hidden');

        document.getElementById('deleteBtn').onclick = () => deleteRedemption(redemptionId);
    }

    function closeModal() {
        document.getElementById('redemptionModal').classList.add('hidden');
    }



async function deleteRedemption(redemptionId) {
  const confirmed = confirm('Are you sure you want to permanently delete this redemption record?');
  if (!confirmed) return;

  try {
    const res = await fetch(`/admin/redemption/${redemptionId}`, { method: 'DELETE' });

    if (!res.ok) {
      const data = await res.json();
      alert(`Error: ${data.message || 'Failed to delete redemption record'}`);
      return;
    }

    const data = await res.json();
    alert(data.message || 'Redemption deleted successfully');
    location.reload();
  } catch (err) {
    console.error('Delete Redemption Error:', err);
    alert('An unexpected error occurred while deleting Redemption.');
  }
}

</script>

</body>
</html>