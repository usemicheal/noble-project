<script>
    $(document).on("click", "#sendmail", function(e) {
        e.preventDefault();

        $(this).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Processing, please wait...')
            .css("pointer-events", "none");

        var formData = new FormData(document.getElementById("sendmail_form"));
        formData.append("contact_form", "contact_form");


        var isValid = true;
        $("#sendmail_form input, #sendmail_form select, #sendmail_form textarea").each(function() { // Separate textarea properly
            if (!$(this).val()) { 
                $(this).addClass("is-invalid"); 
                isValid = false;
            } else {
                $(this).removeClass("is-invalid");
            }
        });
        if (!isValid) {
          
            toastr["warning"]("Form is invalid. Please fill in all required fields.");
          
            $('#sendmail').html('Send Mail').css("pointer-events", "auto");
            return;
        }



        $.ajax({
            url: '/secure/contact',
            type: 'POST',
            data: formData,
            contentType: false,
            cache: false,
            dataType: 'json',
            processData: false,
            success: function(response) {
                if (response.mssg == "ok") {
                    Swal.fire({
                        icon: "success",
                        title: "Success!",
                        text: `Your Mail has been successfully submitted.!`,
                    }).then((result) => {
                        $('#sendmail_form')[0].reset();
                        $('#sendmail').html('Send Mail').css("pointer-events", "auto");
                    });
                } else {
                    Swal.fire({
                        icon: "error",
                        title: "Oops...",
                        text: `${response.mssg}`,
                    });
                }
            },
            error: function(xhr) {
                console.error('Error:', xhr.responseText);
                retry();
            }
        });

    });
</script>

